{
  "name": "react-im",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @react-im/server dev\" \"pnpm --filter @react-im/client start\"",
    "build": "pnpm --filter @react-im/client build",
    "start": "pnpm --filter @react-im/client start",
    "server": "pnpm --filter @react-im/server start",
    "test": "pnpm --filter @react-im/client test",
    "storybook": "pnpm --filter @react-im/client storybook",
    "deploy": "pnpm --filter @react-im/client deploy"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
