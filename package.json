{
  "name": "echo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @echo/server dev\" \"pnpm --filter @echo/client start\"",
    "build": "pnpm --filter @echo/client build",
    "start": "pnpm --filter @echo/client start",
    "server": "pnpm --filter @echo/server start",
    "test": "pnpm --filter @echo/client test",
    "storybook": "pnpm --filter @echo/client storybook",
    "deploy": "pnpm --filter @echo/client deploy"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
